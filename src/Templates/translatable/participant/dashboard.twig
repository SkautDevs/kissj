{% extends "_layout.twig" %}

{% block content %}
{% set celebrationTemplate = event.eventType.getCelebrationTemplate() %}
{% if (celebrate ?? false) and celebrationTemplate %}
    {% include celebrationTemplate %}
{% endif %}
<div class="card">
    <h2>
        {{ ('role.' ~ person.role.value)|trans }}
        {% if person is Leader %}{{ person.getPatrolName }}{% endif %}
        -
        {{ 'dashboard.details' | trans }}
    </h2>
    {% include('widgets/userCustomHelp.twig') %}
    
    {% if person is eligibleForShowTieCode %}
        <h2>
            {% if userStatus == 'paid' and  person.role.value == 'tl'%}
                {{ 'dashboard.pairCode' | trans }} - {{ person.tieCode }}
            {% else %}
                {{ 'dashboard.tieCode' | trans }} - {{ person.tieCode }}
            {% endif %}
        </h2>
    {% endif %}

    {% if event.eventtype.showReceiptToParticipant(person) %}
        <a href="{{ url_for('downloadReceipt', {'eventSlug': event.slug}) }}" target="_blank" class="btn">{{ 'dashboard.downloadReceipt' | trans }}</a><br/>
    {% endif %}
</div>

{% include('widgets/deals.twig') with { person: person } %}

<div class="card">
    {% if person is Leader %}
        <div class="card-divide">
            {#  Patrol/Troop Leader #}
            <div>
                <h2>{{ ('role.' ~ person.role.value)|trans }} {{ person.getFullName }}</h2>
                {% if userStatus == 'open' %}
                    <a class="btn btn-small" href="{{ url_for('showDetailsChangeable', {'eventSlug': event.slug}) }}">
                        {{ 'dashboard.editDetails' | trans }}</a><br/><br/>
                {% elseif userStatus != 'cancelled' and ca.getEditableAfterLockItems() is not empty %}
                    <a class="btn btn-small" href="{{ url_for('showDetailsChangeableAfterLock', {'eventSlug': event.slug}) }}">
                        {{ 'dashboard.editDetailsAfterLock' | trans }}</a><br/><br/>
                {% endif %}
                <div class="text-center">
                    {% include 'widgets/details.twig' with {'person': person} %}
                    <br/>
                </div>
            </div>
            {# Participants #}
            <div>
                <h2>{{ 'dashboard.listOfParticipants' | trans }}</h2>
                {# list of participants in group #}
                {% set count = 1 %}
                <ol class="text-center">
                    {% for p in participants %}
                        <li>
                            {% if person is PatrolLeader %}
                                {{ 'role.p' | trans }} <b>{{ p.getFullName }}</b>
                                {% if userStatus == 'open' %}
                                    <a href="{{ url_for('p-showChangeDetails', {'participantId': p.id, 'eventSlug': event.slug}) }}"><i
                                                class="material-icons">edit</i></a>
                                    <a href="{{ url_for('p-showDelete', {'participantId': p.id, 'eventSlug': event.slug}) }}"><i
                                                class="material-icons">delete</i></a>
                                {% else %}
                                    <a href="{{ url_for('p-show', {'participantId': p.id, 'eventSlug': event.slug}) }}"><i
                                                class="material-icons">search</i></a>
                                {% endif %}
                            {% elseif person is TroopLeader %}
                                {% set participantUserStatus = p.user.status.value %}
                                <span class="{% if participantUserStatus == 'open' %}highlight{% endif %}">
                                    {% if p.user.loginType.value == 'skautis' and p.user.skautisHasMembership == false %}
                                        <img src="https://is.skaut.cz/Login/Favicons/favicon-16x16.png" alt="skautisLogo">
                                        {{ '_layout.skautisAccountNotConnected' | trans }} ❌
                                    {% endif %}
                                    {% if p.isFullNameNotEmpty %}
                                        <b>{{ p.getFullName }}</b>
                                    {% else %}
                                        <i>{{ 'dashboard.withoutFullName' | trans }}</i>
                                    {% endif %}
                                    - {{ ('dashboard.userStatus.' ~ participantUserStatus)|trans }}
                                </span>
                                <a href="{{ url_for('tp-show', {'participantId': p.id, 'eventSlug': event.slug}) }}"><i
                                            class="material-icons">search</i></a>
                                {% if userStatus == 'open' %}
                                    <a href="{{ url_for('tp-showUntie', {'participantId': p.id, 'eventSlug': event.slug}) }}"><i
                                                class="material-icons">delete</i></a>
                                {% endif %}
                            {% endif %}
                        </li>
                        {% set count = count + 1 %}
                    {% endfor %}
                </ol>

                {# help text how many participants is needed #}
                {% if userStatus == 'open' %}
                    <p>
                        {{ 'dashboard.youNeed ' | trans }}
                            {% if person is PatrolLeader %}
                            {% if event.getMinimalPpCount(person) == event.getMaximalPpCount(person) %}
                                {{ 'dashboard.exactly ' | trans }} {{ event.getMinimalPpCount(person) }}
                            {% else %}
                                {{ 'dashboard.minimally ' | trans }} {{ event.getMinimalPpCount(person) }}
                                {{ 'dashboard.andMaximally ' | trans }} {{ event.getMaximalPpCount(person) }}
                            {% endif %}
                        {% elseif person is TroopLeader %}
                            {% if event.getMinimalTroopParticipantsCount == event.getMaximalTroopParticipantsCount %}
                                {{ 'dashboard.exactly ' | trans }} {{ event.getMinimalTroopParticipantsCount }}
                            {% else %}
                                {{ 'dashboard.minimally ' | trans }} {{ event.getMinimalTroopParticipantsCount }}
                                {{ 'dashboard.andMaximally ' | trans }} {{ event.getMaximalTroopParticipantsCount }}
                            {% endif %}
                        {% endif %}
                        {{ 'dashboard.pForValidReg ' | trans }}
                    </p>
                {% endif %}

                {# adding new participants into group #}
                {% if userStatus == 'open' %}
                    {% if person is PatrolLeader %}
                        <a href="{{ url_for('pl-showAddParticipant', {'eventSlug': event.slug}) }}" class="btn btn-small">
                            {{ 'dashboard.addParticipant' | trans }}
                        </a>
                        {% if event.eventType.isLoginSkautisAllowed %}
                            <br/>
                            {% if user.loginType.value == 'skautis' %}
                                <a href="{{ url_for('pl-showAddFromSkautis', {'eventSlug': event.slug}) }}" class="btn btn-small">
                                    {{ 'dashboard.addFromSkautis' | trans }}
                                </a>
                            {% else %}
                                <button class="btn btn-small" disabled title="{{ 'dashboard.addFromSkautisDisabled' | trans }}">
                                    {{ 'dashboard.addFromSkautis' | trans }}
                                </button>
                                <small>{{ 'dashboard.addFromSkautisDisabled' | trans }}</small>
                            {% endif %}
                        {% endif %}
                    {% elseif person is TroopLeader %}
                        {% include('widgets/troopTieForm.twig') with {
                            formUrl: url_for('tie-tp-by-tl', {'eventSlug': event.slug}),
                            textInputLabel: 'dashboard.tieCodeLabel',
                            buttonLabel: 'dashboard.tieTroopParticipant'
                        } %}
                    {% endif %}
                    <br/>
                {% endif %}
            </div>
        </div>
    
        {% if userStatus == 'open' %}
            {% if person is PatrolLeader %}
                {% set linkLeaderLock = url_for('pl-showCloseRegistration', {'eventSlug': event.slug}) %}
            {% elseif person is TroopLeader %}
                {% set linkLeaderLock = url_for('showCloseRegistration', {'eventSlug': event.slug}) %}
            {% endif %}                
            <a class="btn btn-small" href="{{ linkLeaderLock }}">
                {{ 'dashboard.lockRegistration' | trans }}
            </a>
        {% endif %}
    
    {% else %}{# participant #}
            <div>
                {% if person is TroopParticipant %}
                    {% if person.getTroopLeader() is null %}
                        {% include('widgets/troopTieForm.twig') with {
                            formUrl: url_for('tie-tp-by-tp', {'eventSlug': event.slug}),
                            textInputLabel: 'dashboard.codeForTieToTroop',
                            buttonLabel: 'dashboard.tieToTroopLeader'
                        } %}<br/>
                    {% else %}
                        <h2>{{ 'dashboard.youHaveTroop' | trans({'%troopName%': person.troopLeader.getPatrolName(), '%troopLeaderFullName%': person.troopLeader.getFullName()}) }}</h2>
                    {% endif %}
                {% endif %}
                <h2>{{ 'dashboard.personalInfo' | trans }}</h2>
                {% if userStatus == 'open' %}
                    <a class="btn btn-small" href="{{ url_for('showDetailsChangeable', {'eventSlug': event.slug}) }}">
                        {{ 'dashboard.editDetails' | trans }}</a><br/><br/>
                {% elseif userStatus != 'cancelled' and ca.getEditableAfterLockItems() is not empty %}
                    <a class="btn btn-small" href="{{ url_for('showDetailsChangeableAfterLock', {'eventSlug': event.slug}) }}">
                        {{ 'dashboard.editDetailsAfterLock' | trans }}</a><br/><br/>
                {% endif %}
                <div class="text-center">
                    {% include 'widgets/details.twig' with {'person': person} %}
                    <br/>
                </div>
            </div>
    
            {% if userStatus == 'open' %}
                <a class="btn btn-small" href="{{ url_for('showCloseRegistration', {'eventSlug': event.slug}) }}">
                    {{ 'dashboard.lockRegistration' | trans }}</a>
            {% endif %}
        </div>

    {% endif %}
{% endblock %}
