{% extends "_layout.twig" %}

{% block content %}
    <div class="card text-left">
        <h2>{{ 'changeDetails.editDetails' | trans }}</h2>
        <form method="POST"
              action="{% if pDetails.isDetached %}{{ url_for('pl-addParticipant', {'eventSlug': event.slug}) }}{% else %}{{ url_for('p-changeDetails', {'participantId': pDetails.id, 'eventSlug': event.slug}) }}{% endif %}"
              enctype="multipart/form-data">
            {% include 'widgets/changeDetails.twig' with {'personDetails': pDetails, 'editableItems': ca.getAllowedItems()} %}
            <div class="text-center">
                <br/>
                <input class="btn btn-small" type="submit" value="{{ 'changeDetails.save' | trans }}">
                <br/>
                <br/>
                <a class="btn btn-small btn-grey"
                   href="{{ url_for('dashboard', {'eventSlug': event.slug}) }}">
                    {{ 'changeDetails.back' | trans }}
                </a>
            </div>
        </form>
    </div>
{% endblock %}
