{% extends "_layout.twig" %}

{% block content %}
    <div class="card">
        <h2>{{ 'payments-admin.confirmText' | trans }} {{ event.readableName }}</h2>
        {% if event.getEventType.isUnlockExpiredButtonAllowed %}
            <form method="POST" action="{{ url_for('admin-cancel-due-payments', {'eventSlug': event.slug} ) }}">
                <input type="submit" class="btn btn-small" value="{{ 'payments-admin.openDuePayments' | trans }}">
            </form><br/>
        {% endif %}
        <a href="{{ url_for('admin-dashboard', {'eventSlug': event.slug} ) }}"
           class="btn btn-grey btn-small">{{ 'payments-admin.back' | trans }}</a>
    </div>
    <br/>

    {% if event.allowIsts %}
        {% if approvedIsts is empty %}
            <div class="card">
                <h2>{{ 'payments-admin.allIstsPaid' | trans }}</h2>
            </div>
        {% else %}
            <div class="card">
                <h2>{{ 'role.ist' | trans }}</h2>
            </div>
            <br/>
            {% for ist in approvedIsts %}
                <div class="card">
                    {% include 'widgets/paymentDetails.twig' with {
                        'person': ist,
                        'ca': event.getEventType.getContentArbiterIst,
                    } %}
                </div>
                <br/>
            {% endfor %}
        {% endif %}
        <br/>
    {% endif %}
    
    {% if event.allowPatrols %}
        {% if approvedPatrolLeaders is empty %}
            <div class="card">
                <h2>{{ 'payments-admin.allPatrolsPaid' | trans }}</h2>
            </div>
        {% else %}
            <div class="card">
                <h2>{{ 'role.pl' | trans }}</h2>
            </div>
            <br/>
            {% for pl in approvedPatrolLeaders %}
                <div class="card">
                    {% include 'widgets/paymentDetails.twig' with {
                        'person': pl,
                        'ca': event.getEventType.getContentArbiterPatrolLeader,
                    } %}
                </div>
                <br/>
            {% endfor %}
        {% endif %}
        <br/>
    {% endif %}
    
    {% if event.allowTroops %}
        {% if approvedTroopLeaders is empty %}
            <div class="card">
                <h2>{{ 'payments-admin.allTroopLeadersPaid' | trans }}</h2>
            </div>
        {% else %}
            <div class="card">
                <h2>{{ 'role.tl' | trans }}</h2>
            </div>
            <br/>
            {% for tl in approvedTroopLeaders %}
                <div class="card">
                    {% include 'widgets/paymentDetails.twig' with {
                        'person': tl,
                        'ca': event.getEventType.getContentArbiterTroopLeader,
                    } %}
                </div>
                <br/>
            {% endfor %}
        {% endif %}
        <br/>
    {% endif %}
{% endblock %}
