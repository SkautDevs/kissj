{% extends "_layout.twig" %}

{% block content %}
    <div class="card card-half">
        <h2>{{ 'changePaymentPrice-admin.changePrice' | trans }}</h2>
        <p>{{ 'changePaymentPrice-admin.wantChangePrice' | trans }} <b>{{ payment.participant.getFullName }}</b>
            ({{ ('role.' ~ payment.participant.role.value)|trans }})</p>
        <p>{{ 'changePaymentPrice-admin.currentPrice' | trans }}: <b>{{ payment.price }} {{ payment.currency }}</b></p>
        <form method="post" action="{{ url_for('admin-change-payment-price',
            {'paymentId': payment.id, 'eventSlug': event.slug}) }}">
            <div class="form-group">
                <label>{{ 'changePaymentPrice-admin.newPrice' | trans }} ({{ event.currency }}):<br/>
                    <input type="number" min="0" max="99999" name="newPrice" id="form-newPrice"
                           class="form-control form-wide" required="required">
                </label>
            </div>
            <div class="form-group">
                <label>{{ 'changePaymentPrice-admin.reason' | trans }}<br/>
                    <input type="text" name="reason" id="form-reason" class="form-control form-wide"
                           required="required">
                </label>
            </div>
            <br/>
            <a href="{{ url_for('admin-show-payments', {'eventSlug': event.slug}) }}"
               class="btn btn-small btn-grey">{{ 'changePaymentPrice-admin.back' | trans }}</a><br/><br/>
            <input type="submit" value="{{ 'changePaymentPrice-admin.submitChangePrice' | trans }}"
                   class="btn btn-small">
        </form>
    </div>
{% endblock %}
