{% extends "_layout.twig" %}

{% block content %}
    <div class="card card-half">
        <h2>{{ 'addNewPayment-admin.newPayment' | trans }}</h2>
        <p></p>
        <form
            method="post"
            action="{{ url_for('admin-add-new-payment', {'participantId' : participant.getId, 'eventSlug': event.slug}) }}"
        >
            <div class="form-group">
                <label>
                    {{ 'addNewPayment-admin.wantAddPayment' | trans }} <b>{{ participant.getFullName }}</b>
                    {{ 'addNewPayment-admin.withRole' | trans }} <b>{{ ('role.' ~ participant.role.value)|trans }}</b>
                    {{ 'addNewPayment-admin.withPayment' | trans }} ({{ event.currency }}):<br/>
                    <input
                        type="number"
                        min="1"
                        max="99999"
                        name="price"
                        id="form-price"
                        class="form-control form-wide"
                        required="required"
                    >
                </label>
            </div>
            <div class="form-group">
                <label>
                    {{ 'addNewPayment-admin.withReason' | trans }}:<br/>
                    <input
                        type="text"
                        name="reason"
                        id="form-reason"
                        class="form-control form-wide"
                        required="required"
                    >
                </label>
            </div><br/>
            <a
                href="{{ url_for('admin-mend-participant', {'eventSlug': event.slug, 'participantId': participant.getId}) }}"
                class="btn btn-small btn-grey"
            >{{ 'addNewPayment-admin.back' | trans }}</a><br/><br/>
            <input type="submit" value="{{ 'addNewPayment-admin.addPayment' | trans }}" class="btn btn-small">
        </form><br/>
    </div>
{% endblock %}
