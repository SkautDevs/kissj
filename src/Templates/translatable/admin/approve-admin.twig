{% extends "_layout.twig" %}

{% block content %}
    <script src="{{ base_path() }}/js/admin-ajax-submit.js" defer></script>
    <div class="card">
        <h2>{{ 'approve-admin.approving' | trans }} {{ event.readableName }}</h2>
        <a href="{{ url_for('admin-dashboard', {'eventSlug': event.slug} ) }}"
           class="btn btn-grey btn-small">{{ 'approve-admin.back' | trans }}</a>
    </div>
    {% if event.allowIsts %}
        {% if closedIsts is not empty %}
            <div class="card">
                <h2>{{ 'role.ist' | trans }}</h2>
            </div>
            {% for ist in closedIsts %}
                <div class="card">
                    <h4>{{ ist.getFullName }}</h4>
                    {% include 'widgets/detailsForAdmin.twig' with {'person': ist, 'ca': caIst} %}
                    <br/>
                    <a href="{{ url_for('admin-deny-participant-show', {'participantId': ist.getId, 'eventSlug': event.slug}) }}"
                       class="btn btn-grey btn-small">{{ 'approve-admin.deny' | trans }}</a>
                    <br/>
                    <br/>
                    <form method="post"
                          action="{{ url_for('admin-approve', {'participantId': ist.getId, 'eventSlug': event.slug}) }}"
                          class="js-ajax-submit"
                          data-ajax-action="{{ url_for('admin-approve-json', {'participantId': ist.getId, 'eventSlug': event.slug}) }}"
                          data-remove-target=".card"
                          data-error-fallback="{{ 'flash.error.actionFailed' | trans }}">
                        <input type="submit"
                               value="{{ 'approve-admin.approveAndSend' | trans }}"
                               class="btn btn-small">
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <div class="card">
                <h2>{{ 'approve-admin.none' | trans }} {{ 'role.ist' | trans }} {{ 'approve-admin.need' | trans }}</h2>
            </div>
        {% endif %}
    {% endif %}

    {% if event.allowPatrols %}
        {% if closedPatrolLeaders is not empty %}
            <div class="card">
                <h2>{{ 'role.pl' | trans }}</h2>
            </div>
            {% for pl in closedPatrolLeaders %}
                <div class="card">
                    <h3>{{ pl.getPatrolName }}</h3>
                    <br/>
                    <h4>{{ pl.getFullName }}</h4>
                    {% include 'widgets/detailsForAdmin.twig' with {'person': pl, 'ca': caPl} %}
                    <br/>
    
                    <h4>{{ 'role.pp' | trans }} {{ 'dashboard.details' | trans }}</h4>
                    {% for pp in pl.patrolParticipants %}
                        {% include 'widgets/detailsForAdmin.twig' with {'person': pp, 'ca': caPp, 'useShortNaming': true} %}
                        <br/>
                    {% endfor %}
                    <a href="{{ url_for('admin-deny-participant-show', {'participantId': pl.getId, 'eventSlug': event.slug}) }}"
                       class="btn btn-grey btn-small">{{ 'approve-admin.deny' | trans }}</a>
                    <br/>
                    <br/>
                    <form method="post"
                          action="{{ url_for('admin-approve', {'participantId': pl.getId, 'eventSlug': event.slug}) }}"
                          class="js-ajax-submit"
                          data-ajax-action="{{ url_for('admin-approve-json', {'participantId': pl.getId, 'eventSlug': event.slug}) }}"
                          data-remove-target=".card"
                          data-error-fallback="{{ 'flash.error.actionFailed' | trans }}">
                        <input type="submit"
                               value="{{ 'approve-admin.approveAndSend' | trans }}"
                               class="btn btn-small">
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <div class="card">
                <h2>{{ 'approve-admin.none' | trans }} {{ 'role.pl' | trans }} {{ 'approve-admin.need' | trans }}</h2>
            </div>
        {% endif %}
    {% endif %}
    
    {% if event.allowTroops %}
        {% if closedTroopLeaders is not empty %}
            <div class="card">
                <h2>{{ 'role.tl' | trans }}</h2>
            </div>
            {% for tl in closedTroopLeaders %}
                <div class="card">
                    <h3>{{ tl.getPatrolName }}</h3>
                    <br/>
                    <h4>{{ tl.getFullName }}</h4>
                    {% include 'widgets/detailsForAdmin.twig' with {'person': tl, 'ca': caTl} %}
                    <br/>
    
                    <h4>{{ 'role.tp' | trans }} {{ 'dashboard.details' | trans }}</h4>
                    {% for tp in tl.troopParticipants %}
                        {% include 'widgets/detailsForAdmin.twig' with {'person': tp, 'ca': caTp, 'useShortNaming': true} %}
                        <br/>
                    {% endfor %}
                    <a href="{{ url_for('admin-deny-participant-show', {'participantId': tl.getId, 'eventSlug': event.slug}) }}"
                       class="btn btn-grey btn-small">{{ 'approve-admin.deny' | trans }}</a>
                    <br/>
                    <br/>
                    <form method="post"
                          action="{{ url_for('admin-approve', {'participantId': tl.getId, 'eventSlug': event.slug}) }}"
                          class="js-ajax-submit"
                          data-ajax-action="{{ url_for('admin-approve-json', {'participantId': tl.getId, 'eventSlug': event.slug}) }}"
                          data-remove-target=".card"
                          data-error-fallback="{{ 'flash.error.actionFailed' | trans }}">
                        <input type="submit"
                               value="{{ 'approve-admin.approveAndSend' | trans }}"
                               class="btn btn-small">
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <div class="card">
                <h2>{{ 'approve-admin.none' | trans }} {{ 'role.tl' | trans }} {{ 'approve-admin.need' | trans }}</h2>
            </div>
        {% endif %}

        {% if closedTroopParticipants is not empty %}
            <div class="card">
                <h2>{{ 'role.tp' | trans }}</h2>
            </div>
            {% for tp in closedTroopParticipants %}
                <div class="card">
                    <h4>{{ tp.getFullName }}</h4>
                    {% include 'widgets/detailsForAdmin.twig' with {'person': tp, 'ca': caTp} %}
                    <br/>
                    
                    <a href="{{ url_for('admin-deny-participant-show', {'participantId': tp.getId, 'eventSlug': event.slug}) }}"
                       class="btn btn-grey btn-small">{{ 'approve-admin.deny' | trans }}</a>
                    <br/>
                    <br/>
                    <form method="post"
                          action="{{ url_for('admin-approve', {'participantId': tp.getId, 'eventSlug': event.slug}) }}"
                          class="js-ajax-submit"
                          data-ajax-action="{{ url_for('admin-approve-json', {'participantId': tp.getId, 'eventSlug': event.slug}) }}"
                          data-remove-target=".card"
                          data-error-fallback="{{ 'flash.error.actionFailed' | trans }}">
                        <input type="submit"
                               value="{{ 'approve-admin.approveAndSend' | trans }}"
                               class="btn btn-small">
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <div class="card">
                <h2>{{ 'approve-admin.none' | trans }} {{ 'role.tp' | trans }} {{ 'approve-admin.need' | trans }}</h2>
            </div>
        {% endif %}
    {% endif %}

    {% if event.allowGuests %}
        {% if closedGuests is not empty %}
            <div class="card">
                <h2>{{ 'role.guest' | trans }}</h2>
            </div>
            {% for guest in closedGuests %}
                <div class="card">
                    <h4>{{ guest.getFullName }}</h4>
                    {% include 'widgets/detailsForAdmin.twig' with {'person': guest, 'ca': caGuest} %}
                    <br/>
                    <a href="{{ url_for('admin-deny-participant-show', {'participantId': guest.getId, 'eventSlug': event.slug}) }}"
                       class="btn btn-grey btn-small">{{ 'approve-admin.deny' | trans }}</a>
                    <br/>
                    <br/>
                    <form method="post"
                          action="{{ url_for('admin-approve', {'participantId': guest.getId, 'eventSlug': event.slug}) }}"
                          class="js-ajax-submit"
                          data-ajax-action="{{ url_for('admin-approve-json', {'participantId': guest.getId, 'eventSlug': event.slug}) }}"
                          data-remove-target=".card"
                          data-error-fallback="{{ 'flash.error.actionFailed' | trans }}">
                        <input type="submit" value="{{ 'approve-admin.approveAndSend' | trans }}" class="btn btn-small">
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <div class="card">
                <h2>{{ 'approve-admin.none' | trans }} {{ 'role.guest' | trans }} {{ 'approve-admin.need' | trans }}</h2>
            </div>
        {% endif %}
    {% endif %}

    {% if event.allowOrganizingTeam %}
        {% if closedOrganizingTeam is not empty %}
            <div class="card">
                <h2>{{ 'role.ot' | trans }}</h2>
            </div>
            {% for ot in closedOrganizingTeam %}
                <div class="card">
                    <h4>{{ ot.getFullName }}</h4>
                    {% include 'widgets/detailsForAdmin.twig' with {'person': ot, 'ca': caOt} %}
                    <br/>
                    <a href="{{ url_for('admin-deny-participant-show', {'participantId': ot.getId, 'eventSlug': event.slug}) }}"
                       class="btn btn-grey btn-small">{{ 'approve-admin.deny' | trans }}</a>
                    <br/>
                    <br/>
                    <form method="post"
                          action="{{ url_for('admin-approve', {'participantId': ot.getId, 'eventSlug': event.slug}) }}"
                          class="js-ajax-submit"
                          data-ajax-action="{{ url_for('admin-approve-json', {'participantId': ot.getId, 'eventSlug': event.slug}) }}"
                          data-remove-target=".card"
                          data-error-fallback="{{ 'flash.error.actionFailed' | trans }}">
                        <input type="submit" value="{{ 'approve-admin.approveAndSend' | trans }}" class="btn btn-small">
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <div class="card">
                <h2>{{ 'approve-admin.none' | trans }} {{ 'role.ot' | trans }} {{ 'approve-admin.need' | trans }}</h2>
            </div>
        {% endif %}
    {% endif %}
{% endblock %}
