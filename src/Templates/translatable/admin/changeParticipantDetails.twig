{% extends "_layout.twig" %}

{% block content %}
    <div class="card text-left">
        <h2>{{ 'changeDetails.editDetails' | trans }}</h2>
        <form method="POST" action="{{ url_for('admin-change-participant-details', {'eventSlug': event.slug, 'participantId': person.id}) }}"
              enctype="multipart/form-data">
            {% include 'widgets/changeDetails.twig' with {'personDetails': person, 'editableItems': ca.getAllowedItems()} %}
            <div class="text-center">
                <br/>
                <input class="btn btn-small" type="submit" value="{{ 'changeDetails.save' | trans }}">
                <br/>
                <br/>
                <a class="btn btn-small btn-grey"
                   href="{{ url_for('admin-mend-participant', {'eventSlug': event.slug, 'participantId': person.id}) }}">{{ 'changeDetails.back' | trans }}</a>
            </div>
        </form>
    </div>
{% endblock %}
