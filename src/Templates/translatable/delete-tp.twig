{% extends "_layout.twig" %}

{% block content %}
    <div class="card">
        <h2>{{ 'dashboard.untie' | trans }} - {{ 'role.tp' | trans }}</h2>
        <p>
            {{ 'dashboard.youWantUntie' | trans }}
            {% if pDetail.getFirstName is not empty %}<b>{{ pDetail.getFullName }}</b>{% else %}
                <i>{{ 'dashboard.withoutName' | trans }}</i>{% endif %}?
        </p>
        <form method="POST"
              action="{{ url_for('tp-untie', {'participantId': pDetail.getId, 'eventSlug': event.slug}) }}">
            <input class="btn btn-small" type="submit" value="{{ 'dashboard.untie' | trans }}">
            <a href="{{ url_for('dashboard', {'eventSlug': event.slug}) }}"
               class="btn btn-grey btn-small">{{ 'changeDetails.back' | trans }}</a>
        </form>
    </div>
{% endblock %}
