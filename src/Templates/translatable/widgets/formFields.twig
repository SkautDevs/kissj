{#
    Renders a form input field for changeDetails.twig.

    @param item          ContentArbiterItem instance
    @param value         Current field value (from personDetails getter)
    @param personDetails The participant entity (for special-case getters)
    @param event         The event entity (for dates, contingents, food options, etc.)
    @param user          The user entity (for email fallback)
#}
{% macro renderField(item, value, personDetails, event, user) %}
    {% if item.type.value == 'text' or item.type.value == 'phone' %}
        <div class="form-group"
            {% if item.ageGroup %}
                data-age-group="{{ item.ageGroup.value }}"
                {% if not item.appliesToAge(personDetails.getAgeAtStartOfEvent) %}style="display:none"{% endif %}
            {% endif %}
        >
            <label for="{{ item.slug }}">{{ item.label|trans }}:</label>
            <input
                id="{{ item.slug }}"
                class="form-control form-wide"
                type="text"
                name="{{ item.slug }}"
                {% if item.placeholder %}placeholder="{{ item.placeholder|trans }}"{% endif %}
                value="{{ value }}"
                {% if item.pattern %}pattern="{{ item.pattern }}"{% endif %}
                {% if item.required %}required="required"{% endif %}
            >
        </div>
    {% elseif item.type.value == 'email' %}
        <div class="form-group">
            <label for="{{ item.slug }}">{{ item.label|trans }}:</label>
            <input
                id="{{ item.slug }}"
                class="form-control form-wide"
                type="email"
                name="{{ item.slug }}"
                value="{% if value is empty and personDetails.role != 'pp' %}{{ user.email }}{% else %}{{ value }}{% endif %}"
                {% if item.placeholder %}placeholder="{{ item.placeholder|trans }}"{% endif %}
                {% if item.required %}required="required"{% endif %}
            >
        </div>
    {% elseif item.type.value == 'date' %}
        <div class="form-group">
            <label for="{{ item.slug }}">{{ item.label|trans }}:</label>
            <input
                id="{{ item.slug }}"
                class="form-control{% for cls in item.extraClasses %} {{ cls }}{% endfor %}"
                type="date"
                name="{{ item.slug }}"
                value="{% if value %}{{ value|date('Y-m-d') }}{% elseif item.slug == 'arrivalDate' %}{{ event.startDay|date('Y-m-d') }}{% elseif item.slug == 'departureDate' %}{{ event.endDay|date('Y-m-d') }}{% elseif item.defaultValue %}{{ item.defaultValue }}{% endif %}"
                {% if item.required %}required="required"{% endif %}
                {% if item.slug == 'birthDate' %}data-event-start-day="{{ event.startDay.getTimestamp() }}"{% endif %}
            >
        </div>
    {% elseif item.type.value == 'select' %}
        <div class="form-group">
            <label for="{{ item.slug }}">{{ item.label|trans }}:</label>
            <select
                id="{{ item.slug }}"
                class="form-control form-wide"
                name="{{ item.slug }}"
                {% if item.required %}required="required"{% endif %}
            >
                {% for dbValue, transKey in item.options %}
                    <option
                        value="{{ dbValue }}"
                        {% if value == dbValue %}selected="selected"{% endif %}
                    >
                        {{ transKey|trans }}
                    </option>
                {% endfor %}
            </select>
        </div>
        {% if item.helpText %}
            {{ item.helpText|trans }}
            <br><br>
        {% endif %}
    {% elseif item.type.value == 'textarea' %}
        <div class="form-group">
            <label for="{{ item.slug }}">{{ item.label|trans }}:</label>
            <textarea
                id="{{ item.slug }}"
                class="form-control form-wide"
                type="text"
                name="{{ item.slug }}"
                {% if item.placeholder %}placeholder="{{ item.placeholder|trans }}"{% endif %}
            >{{ value }}</textarea>
        </div>
    {% elseif item.type.value == 'file' %}
        <div id="{{ item.slug }}Form" class="form-group"
            {% if item.ageGroup %}
                data-age-group="{{ item.ageGroup.value }}"
                {% if not item.appliesToAge(personDetails.getAgeAtStartOfEvent) %}style="display:none"{% endif %}
            {% endif %}
        >
            <label>{{ item.label|trans }}:
                <input id="{{ item.slug }}" class="form-control form-group-inline" type="file" name="{{ item.slug }}"
                        {% if not value %} {% endif %}>
            </label>
            {% if value %}
                {% set storedFilename = personDetails.getUploadedFilename(item.slug) %}
                <b>
                    <a target="_blank" href="{{ url_for('show-file', {'filename': storedFilename, 'eventSlug': event.slug}) }}">
                        {{ value }}
                    </a>
                    {{ 'detail.uploadedFileSuccessful' | trans }}
                </b>
            {% endif %}
            {{ 'detail.uploadedFileNote' | trans | raw }}
        </div>
    {% elseif item.type.value == 'checkbox' %}
        {% if item.slug == 'preferredPosition' %}
            <div class="form-group">
                <label for="position">{{ 'detail.position-title' | trans }}:</label>
                {% for dbValue, transKey in item.options %}
                    <label class="form-control">
                        <input type="checkbox" name="preferredPosition[]" value="{{ dbValue }}"
                               {% if dbValue in personDetails.preferredPosition %}checked="checked"{% endif %}>
                        {{ transKey|trans }}
                    </label>
                {% endfor %}
            </div>
            {{ 'detail.position-placeholder' | trans }}
            <br>
        {% elseif item.slug == 'printedHandbook' %}
            <div class="form-group">
                <label for="{{ item.slug }}">{{ 'detail.printedHandbook-detail' | trans }}: </label>
                <input
                        id="{{ item.slug }}"
                        type="checkbox"
                        name="{{ item.slug }}"
                        value="yes"
                        {% if personDetails.getPrintedHandbook %} checked{% endif %}
                >
            </div>
        {% else %}
            <div class="form-group">
                <label for="{{ item.slug }}">{{ item.label|trans }}:</label>
                <input
                    id="{{ item.slug }}"
                    type="checkbox"
                    name="{{ item.slug }}"
                    value="yes"
                    {% if value %} checked{% endif %}
                >
            </div>
        {% endif %}
    {% elseif item.type.value == 'tshirtComposite' %}
        <div class="form-group">
            <label for="tshirtShape">{{ 'detail.tshirtGender' | trans }}:</label>
            <select id="tshirtShape" class="form-control form-wide" name="tshirtShape" required="required">
                <option value="detail.tshirtGenderFemale"
                        {% if personDetails.getTshirtShape == 'detail.tshirtGenderFemale' %}selected="selected"{% endif %}>
                    {{ 'detail.tshirtGenderFemale' | trans }}
                </option>
                <option value="detail.tshirtGenderMale"
                        {% if personDetails.getTshirtShape == 'detail.tshirtGenderMale' %}selected="selected"{% endif %}>
                    {{ 'detail.tshirtGenderMale' | trans }}
                </option>
            </select>
        </div>
        <div class="form-group">
            <label for="tshirtSize">{{ 'detail.tshirtSize' | trans }}:</label>
            <select
                id="tshirtSize"
                class="form-control form-wide"
                name="tshirtSize"
                required="required"
            >
                <option value="detail.tshirtXS" {% if personDetails.getTshirtSize == 'detail.tshirtXS' %}selected="selected"{% endif %}>
                    {{ 'detail.tshirtXS' | trans }}
                </option>
                <option value="detail.tshirtS" {% if personDetails.getTshirtSize == 'detail.tshirtS' %}selected="selected"{% endif %}>
                    {{ 'detail.tshirtS' | trans }}
                </option>
                <option value="detail.tshirtM" {% if personDetails.getTshirtSize == 'detail.tshirtM' %}selected="selected"{% endif %}>
                    {{ 'detail.tshirtM' | trans }}
                </option>
                <option value="detail.tshirtL" {% if personDetails.getTshirtSize == 'detail.tshirtL' %}selected="selected"{% endif %}>
                    {{ 'detail.tshirtL' | trans }}
                </option>
                <option value="detail.tshirtXL" {% if personDetails.getTshirtSize == 'detail.tshirtXL' %}selected="selected"{% endif %}>
                    {{ 'detail.tshirtXL' | trans }}
                </option>
                <option value="detail.tshirtXXL" {% if personDetails.getTshirtSize == 'detail.tshirtXXL' %}selected="selected"{% endif %}>
                    {{ 'detail.tshirtXXL' | trans }}
                </option>
            </select>
        </div>
    {% endif %}
{% endmacro %}

{#
    Renders a read-only detail display for details.twig.

    @param item   ContentArbiterItem instance
    @param value  Current field value (from person getter)
    @param person The participant entity
    @param event  The event entity (for upload file admin link)
#}
{% macro renderDetail(item, value, person, event) %}
    {% if item.type.value == 'tshirtComposite' %}
        {{ item.label|trans }}: <b>{% if person.getTshirtShape %}{{ person.getTshirtShape|trans }} - {{ person.getTshirtSize|trans }}{% endif %}</b><br/>
    {% elseif item.type.value == 'select' %}
        {{ item.label|trans }}: <b>{% if value and item.options[value] is defined %}{{ item.options[value]|trans }}{% elseif value %}{{ value }}{% endif %}</b><br/>
    {% elseif item.slug == 'birthDate' %}
        {{ item.label|trans }}: <b>{% if value %}{{ value.format('d. m. Y') }}{% endif %}</b>
            {% if value %}
                ({{ person.getAgeAtStartOfEvent }} {{ 'detail.birthDateYearsAtEvent' | trans }})
            {% endif %}<br/>
    {% elseif item.slug == 'arrivalDate' or item.slug == 'departureDate' %}
        {{ item.label|trans }}: <b>{% if value %}{{ value.format('d. m. Y') }}{% endif %}</b><br/>
    {% elseif item.slug == 'preferredPosition' %}
        {{ 'detail.position-title' | trans }}: <b>
            {% for preferredPosition in person.preferredPosition %}
                {{ preferredPosition|trans }}{% if not loop.last %}, {% endif %}
            {% endfor %}
        </b><br/>
    {% elseif item.slug == 'printedHandbook' %}
        {{ item.label|trans }}: <b>
            {% if value %}{{ 'detail.handbook-yes' | trans }}{% else %}{{ 'detail.handbook-no' | trans }}{% endif %}</b><br/>
    {% elseif item.type.value == 'file' %}
        {{ item.label|trans }}:
        {% set filename = person.getUploadedFilename(item.slug) %}
        {% if filename %}
            <a target="_blank"
               href="{{ url_for('show-file', {'filename': filename, 'eventSlug': event.slug}) }}">
                {{ value }}
            </a>
        {% else %}
            {{ 'detail.uploadFileMissing'|trans }}
        {% endif %}<br/>
    {% else %}
        {{ item.label|trans }}: <b>{{ value }}</b><br/>
    {% endif %}
{% endmacro %}
