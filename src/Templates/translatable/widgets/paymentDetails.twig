<h4>{{ person.getFullName }}</h4>
{{ 'payments-admin.email' | trans }}: <b>{{ person.user.getEmail }}</b><br/>
<a
    href="{{ url_for('admin-show-add-new-payment', {'participantId': person.id, 'eventSlug': event.slug}) }}"
    class="btn btn-small btn-mini"
>{{ 'mend-admin.addPayment' | trans }}</a></br>
{% if ca.contingent.allowed %}
    {{ 'detail.contingentTitle' | trans }}: <b>{{ person.getContingent|trans }}</b><br/>
{% endif %}{% if ca.notes.allowed %}
    {{ 'detail.notice' | trans }}: <b>{{ person.getNotes }}</b><br/>
{% endif %}
{% include 'widgets/adminNotice.twig' with {'participantId': person.id} %}
<br>
{% include 'widgets/paymentList.twig' with {'payments': person.getPayments} %}
