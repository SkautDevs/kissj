{% import 'widgets/formFields.twig' as forms %}

{% for item in editableItems %}
    {% if item.type.value == 'tshirtComposite' %}
        {{ forms.renderField(item, null, personDetails, event, user) }}
    {% else %}
        {{ forms.renderField(item, personDetails.getValueForField(item.slug), personDetails, event, user) }}
    {% endif %}
{% endfor %}

<script src="{{ base_path() }}/js/age-group-toggle.js" defer></script>
