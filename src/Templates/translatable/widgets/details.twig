{% import 'widgets/formFields.twig' as forms %}

{% if useShortNaming %}
    {% if person.getFullName == " " %}<i>{% trans %}dashboard.withoutFullName {% endtrans %}</i>{% else %}<b>{{ person.getFullName }}</b>{% endif %}<br/>
{% endif %}

{% for item in ca.getAllowedItems() %}
    {% if item.slug == 'firstName' or item.slug == 'lastName' or item.slug == 'nickname' %}
        {% if not useShortNaming %}
            {{ forms.renderDetail(item, person.getValueForField(item.slug), person, event) }}
        {% endif %}
    {% elseif item.type.value == 'tshirtComposite' or item.type.value == 'checkbox' %}
        {{ forms.renderDetail(item, null, person, event) }}
    {% else %}
        {{ forms.renderDetail(item, person.getValueForField(item.slug), person, event) }}
    {% endif %}
{% endfor %}
