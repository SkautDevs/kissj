{% extends "_layout.twig" %}

{% block content %}
    <div class="two-cards">
        <div class="card">
            <h2>{{ 'landing.features.title' | trans }}</h2>
            <ul>
                <li>{{ 'landing.features.setup' | trans }}</li>
                <li>{{ 'landing.features.emails' | trans }}</li>
                <li>{{ 'landing.features.payments' | trans }}</li>
                <li>{{ 'landing.features.export' | trans }}</li>
            </ul>
        </div>
        <div class="card">
            <h2>{{ 'landing.cta.title' | trans }}</h2>
            <p>{{ 'landing.cta.description' | trans }}</p>
            <a target="_blank" href="https://github.com/SkautDevs/kissj">{{ 'landing.cta.github' | trans }}</a>
        </div>
    </div>

    <div class="landing-logos">
        <div class="landing-logos-track">
            <div class="landing-logos-inner">
                {% for copy in 0..1 %}
                    <div class="landing-logos-slide"{{ copy > 0 ? ' aria-hidden="true"' : '' }}>
                        {% for pastEvent in allEvents %}
                            <figure class="landing-logo-item">
                                <img src="{{ pastEvent.logoUrl }}" alt="{{ copy == 0 ? pastEvent.readableName : '' }}" loading="lazy">
                                <figcaption>{{ pastEvent.readableName }}</figcaption>
                            </figure>
                        {% endfor %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
    <div class="card">
        <h2>{{ 'landing.events.title' | trans }}</h2>
        {% for event in events %}
            <p><a href="{{ url_for('landing', {'eventSlug': event.slug}) }}" class="btn">{{ event.readableName }}</a></p>
        {% endfor %}
    </div>
{% endblock %}
