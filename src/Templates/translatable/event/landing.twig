{% extends "_layout.twig" %}

{% block content %}
    <div class="two-cards">
        <div class="card">
            <h2>{% trans %}landing.features.title{% endtrans %}</h2>
            <ul>
                <li>{% trans %}landing.features.setup{% endtrans %}</li>
                <li>{% trans %}landing.features.emails{% endtrans %}</li>
                <li>{% trans %}landing.features.payments{% endtrans %}</li>
                <li>{% trans %}landing.features.export{% endtrans %}</li>
            </ul>
        </div>
        <div class="card">
            <h2>{% trans %}landing.cta.title{% endtrans %}</h2>
            <p>{% trans %}landing.cta.description{% endtrans %}</p>
            <a target="_blank" href="https://github.com/SkautDevs/kissj">{% trans %}landing.cta.github{% endtrans %}</a>
        </div>
    </div>

    <div class="landing-logos">
        <div class="landing-logos-track">
            <div class="landing-logos-inner">
                {% for copy in 0..1 %}
                    <div class="landing-logos-slide"{{ copy > 0 ? ' aria-hidden="true"' : '' }}>
                        {% for pastEvent in allEvents %}
                            <figure class="landing-logo-item">
                                <img src="{{ pastEvent.logoUrl }}" alt="{{ copy == 0 ? pastEvent.readableName : '' }}" loading="lazy">
                                <figcaption>{{ pastEvent.readableName }}</figcaption>
                            </figure>
                        {% endfor %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
    <div class="card">
        <h2>{% trans %}landing.events.title{% endtrans %}</h2>
        {% for event in events %}
            <p><a href="{{ url_for('landing', {'eventSlug': event.slug}) }}" class="btn">{{ event.readableName }}</a></p>
        {% endfor %}
    </div>
{% endblock %}
